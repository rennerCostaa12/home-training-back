{
  "name": "boilerplate-nodejs",
  "version": "1.0.0",
  "description": "Boilerplate Node.js com Express, TypeScript, Sequelize, MySQL, Yup e arquitetura em camadas.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "sequelize",
    "mysql",
    "yup"
  ],
  "author": "Renner Costa",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.11.3",
    "sequelize": "^6.37.3",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.4",
    "sequelize-cli": "^6.6.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
